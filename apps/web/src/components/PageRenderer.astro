---
import type { Locale, PageContent, PageKey } from '../content/site';

interface Props {
  locale: Locale;
  pageKey: PageKey;
  page: PageContent;
}

const { locale, pageKey, page } = Astro.props;
const isHome = pageKey === 'home';
const isLegal = pageKey === 'privacy' || pageKey === 'terms';
const sectionLabel = locale === 'en' ? 'Section' : 'Sección';
---

<section class:list={['hero', isHome && 'hero-home']}>
  <div class="shell hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">{page.eyebrow}</p>
      <h1>{page.title}</h1>
      <p class="hero-lead">{page.lead}</p>
      {(page.primaryAction || page.secondaryAction) && (
        <div class="action-row">
          {page.primaryAction && (
            <a class="button" href={page.primaryAction.href}>{page.primaryAction.label}</a>
          )}
          {page.secondaryAction && (
            <a class="text-link" href={page.secondaryAction.href}>{page.secondaryAction.label}<span aria-hidden="true"> ↗</span></a>
          )}
        </div>
      )}
    </div>

    <aside class="hero-aside" aria-label={locale === 'en' ? 'Positioning' : 'Posicionamiento'}>
      <span class="hero-index" aria-hidden="true">{String(pageKey === 'home' ? 0 : 1).padStart(2, '0')}</span>
      <p>{page.description}</p>
      {isHome && (
        <dl class="signal-list">
          <div><dt>01</dt><dd>{locale === 'en' ? 'Senior advisory' : 'Asesoría senior'}</dd></div>
          <div><dt>02</dt><dd>{locale === 'en' ? 'Hands-on delivery' : 'Ejecución práctica'}</dd></div>
          <div><dt>03</dt><dd>{locale === 'en' ? 'Independent judgement' : 'Criterio independiente'}</dd></div>
        </dl>
      )}
    </aside>
  </div>
</section>

<div class:list={['page-sections', isLegal && 'legal-sections']}>
  {page.sections.map((section, sectionIndex) => (
    <section class="content-section">
      <div class="shell section-grid">
        <header class="section-heading">
          <p class="section-number">{section.eyebrow ?? `${sectionLabel} ${String(sectionIndex + 1).padStart(2, '0')}`}</p>
          <h2>{section.title}</h2>
        </header>

        <div class="section-content">
          {section.body?.map((paragraph) => <p>{paragraph}</p>)}
          {section.items && (
            <div class:list={['card-grid', section.items.length === 1 && 'card-grid-single']}>
              {section.items.map((item, itemIndex) => {
                const content = (
                  <>
                    <div class="card-topline">
                      <span>{String(itemIndex + 1).padStart(2, '0')}</span>
                      {item.meta && <small>{item.meta}</small>}
                    </div>
                    <h3>{item.title}</h3>
                    <p>{item.body}</p>
                    {item.href && <span class="card-link">{locale === 'en' ? 'Explore' : 'Explorar'} ↗</span>}
                  </>
                );
                return item.href ? <a class="content-card content-card-link" href={item.href}>{content}</a> : <article class="content-card">{content}</article>;
              })}
            </div>
          )}
        </div>
      </div>
    </section>
  ))}
</div>

{!isLegal && (
  <section class="closing-band">
    <div class="shell closing-grid">
      <p class="eyebrow">{locale === 'en' ? 'Next decision' : 'Siguiente decisión'}</p>
      <h2>{locale === 'en' ? 'Make the problem explicit. Then design the system.' : 'Haz explícito el problema. Luego diseña el sistema.'}</h2>
      <a class="button button-inverse" href={locale === 'en' ? '/contact' : '/es/contacto'}>
        {locale === 'en' ? 'Start a conversation' : 'Iniciar conversación'}
      </a>
    </div>
  </section>
)}
