---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#0d1715" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>Page not found · Carlos Pinto</title>
  </head>
  <body>
    <main class="language-choice" id="content">
      <section class="not-found">
        <p class="eyebrow">404 · Page not found · Página no encontrada</p>
        <h1>This route does not exist.</h1>
        <p>
          The page may have moved. Choose a language to return home.<br />
          La página puede haberse movido. Elige un idioma para volver al inicio.
        </p>
        <div class="action-row">
          <a class="button" href="/">English</a>
          <a class="button" href="/es">Español</a>
        </div>
      </section>
    </main>
  </body>
</html>
