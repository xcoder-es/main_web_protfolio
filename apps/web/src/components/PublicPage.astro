---
import { getPageContent } from '../content';
import type { Locale, PageKey } from '../content/site';
import '../styles/forms.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import ClosingBand from './ClosingBand.astro';
import LeadForm from './LeadForm.astro';
import PageRenderer from './PageRenderer.astro';

interface Props {
  locale: Locale;
  pageKey: PageKey;
}

const { locale, pageKey } = Astro.props;
const page = getPageContent(locale, pageKey);
const formKind =
  pageKey === 'contact' ? 'contact' : pageKey === 'requestProject' ? 'project' : undefined;
---

<BaseLayout locale={locale} pageKey={pageKey} title={page.title} description={page.description}>
  <PageRenderer locale={locale} pageKey={pageKey} page={page} showClosing={!formKind} />
  {formKind && <LeadForm locale={locale} kind={formKind} />}
  {formKind && <ClosingBand locale={locale} />}
</BaseLayout>
